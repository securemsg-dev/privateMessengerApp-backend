# ============================================================
# Private Messenger App — Environment Configuration
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# In production, use AWS Secrets Manager instead of .env.
# ============================================================

# --- App ---
APP_ENV=development          # development | staging | production
APP_NAME="Private Messenger"
DEBUG=true
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/private_messenger
# Example prod: postgresql+asyncpg://user:pass@rds-endpoint.amazonaws.com:5432/private_messenger

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
# Example prod (ElastiCache): redis://your-elasticache-endpoint.amazonaws.com:6379/0

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- OTP ---
# OTP_MODE: "mock" (local dev, OTP printed to console) | "aws_sns" (production)
OTP_MODE=mock
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# --- AWS SNS (only needed when OTP_MODE=aws_sns) ---
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SNS_SENDER_ID=PrivateMsg    # Displayed as sender name on SMS (not all regions support this)

# --- AWS S3 (profile pictures) ---
AWS_S3_BUCKET_NAME=private-messenger-media
AWS_S3_PRESIGN_EXPIRY_SECONDS=3600

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
