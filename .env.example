# ============================================================
# Private Messenger App — Environment Configuration
# ============================================================
# Copy this file to .env.local (development) and fill in real values.
# NEVER commit env files to version control.
# In production (Railway), set these as service variables instead.
# ============================================================

# --- App ---
APP_ENV=development          # development | staging | production
APP_NAME="Cricchat"
DEBUG=true

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/private_messenger
# Railway supplies postgresql:// — the app rewrites it to +asyncpg automatically.

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Rate limiting ---
# Keep true in production. Set false ONLY for single-IP load tests.
RATE_LIMITING_ENABLED=true

# --- Media storage ---
# "local" writes encrypted blobs to MEDIA_LOCAL_PATH (mount a persistent
# volume in production or media is lost on redeploy). "s3" is not yet
# implemented.
MEDIA_STORAGE_BACKEND=local
MEDIA_LOCAL_PATH=./uploads

# --- WebRTC ---
# Comma-separated STUN URIs; TURN is required for ~20% of mobile networks.
WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
WEBRTC_TURN_URL=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_PASSWORD=

# --- AWS S3 (future media backend — unused while MEDIA_STORAGE_BACKEND=local) ---
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET_NAME=private-messenger-media
AWS_S3_PRESIGN_EXPIRY_SECONDS=3600

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
